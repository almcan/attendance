# Slack Bot 設定
# 1. メンバーへのメンションやメッセージ送信に使用 (xoxb-...)
SLACK_BOT_TOKEN=

# 2. 通知を送るチャンネル名 (例: #attendance-notices)
SLACK_CHANNEL=#attendance-notices

# 3. Socket Mode で DM を受信するために必要な App Token (xapp-...)
#    Slack App の設定で "Socket Mode" を有効にして発行してください
SLACK_APP_TOKEN=

# (参考) Webhook を使う場合のみ記入
SLACK_WEBHOOK_URL=

# ─── 管理者認証 ──────────────────────────────────────────────
# generate_admin_hash.py を実行して生成したハッシュ値を設定してください
# 使い方: .venv/bin/python generate_admin_hash.py
ADMIN_USERNAME_HASH=
ADMIN_PASSWORD_HASH=

# Flask セッション用の秘密鍵（generate_admin_hash.py が自動生成します）
FLASK_SECRET_KEY=
