# Slack Bot 設定
# 1. メンバーへのメンションやメッセージ送信に使用 (xoxb-...)
SLACK_BOT_TOKEN=

# 2. 通知を送るチャンネル名 (例: #attendance-notices)
SLACK_CHANNEL=#attendance-notices

# 3. Socket Mode を使用する場合に必要な App Token (xapp-...)
# ※ cron 通知だけであれば不要ですが、将来的にボットを常駐させる場合に必要です
SLACK_APP_TOKEN=

# (参考) Webhook を使う場合のみ記入
SLACK_WEBHOOK_URL=
